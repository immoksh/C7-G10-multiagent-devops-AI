# =====================================================================
# AI-Powered Multi-Agent DevOps Incident Analysis Platform
# Copy this file to `.env` and fill in the values you have.
# Every integration is OPTIONAL — the app degrades gracefully and runs
# in "dry-run" / rule-based mode when credentials are missing.
# =====================================================================

# ---------------------------------------------------------------------
# LLM layer — OpenRouter (preferred, OpenAI-compatible)
# Get an API key at https://openrouter.ai/keys
# Leave OPENROUTER_API_KEY blank to fall back to Hugging Face / rule-based.
# ---------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.2

# ---------------------------------------------------------------------
# LLM layer — Hugging Face Inference (alternative, used only if no
# OPENROUTER_API_KEY is set). Get a token at
# https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# ---------------------------------------------------------------------
# Embeddings for the Chroma runbook vector store (RAG).
# Runs locally via sentence-transformers (free, offline). NOTE: OpenRouter
# does NOT provide an embeddings endpoint, so embeddings stay local.
# ---------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=vectorstore/chroma_db

# ---------------------------------------------------------------------
# Slack notifications (Notification Agent)
# Create a bot token at https://api.slack.com/apps -> OAuth & Permissions
# Needs scope: chat:write
# ---------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#incidents

# ---------------------------------------------------------------------
# Jira ticketing (Jira Agent)
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
# ---------------------------------------------------------------------
JIRA_SERVER=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS
